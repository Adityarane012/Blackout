# ========================================
# BLACKOUT - Git Ignore Configuration
# ========================================

# ----------------------------------------
# 1. Secrets & Environment Variables
# ----------------------------------------
# Ignore all environment files containing secrets.
.env
.env.*
!.env.example

# SSH and Keys
*.pem
*.key
*.cert

# ----------------------------------------
# 2. Python & Backend
# ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.pytest_cache/
.mypy_cache/

# ----------------------------------------
# 3. Node.js & Frontend
# ----------------------------------------
node_modules/
.pnpm-store/
.npm/

# Next.js Build Outputs
.next/
out/
dist/
build/

# TypeScript Cache
*.tsbuildinfo

# ----------------------------------------
# 4. Databases & Storage
# ----------------------------------------
*.db
*.sqlite3
*.sqlite
data/
neo4j_data/

# ----------------------------------------
# 5. Graphify (AI Agent Knowledge Graph)
# ----------------------------------------
graphify-out/cache/
graphify-out/.graphify_*
graphify-out/*.json
graphify-out/*.html
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_uncached.txt

# ----------------------------------------
# 6. Logs & Debugging
# ----------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.coverage

# ----------------------------------------
# 7. OS & IDE Metadata
# ----------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/

# ----------------------------------------
# 8. Private / Scratch Files
# ----------------------------------------
scratch*.py
test*.py
for_creator_update.md