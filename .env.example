# ========================================
# BLACKOUT - Environment Variables Template
# ========================================
# Copy this file to .env.local and fill in the values below.

# 1. Clerk Authentication (Required for Dashboard Access)
# Sign up at https://clerk.com to get these keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# 2. Neo4j Graph Database (Required for AI Pre-Scan)
# You can use a local Neo4j Desktop instance or a free AuraDB cloud instance.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# 3. Production Deployment Only
# If hosting the Next.js frontend on Vercel, set this to your Render/Railway backend URL.
# Do NOT set this for local development (it defaults to http://127.0.0.1:8000).
# BACKEND_URL=https://blackout-api.onrender.com
