# ========================================
# BLACKOUT - Environment Variables Template
# ========================================
# HOW TO USE: 
# Copy this file, rename it to `.env.local`, and fill in your keys.
# NEVER commit `.env.local` to version control.

# ----------------------------------------
# 1. Clerk Authentication
# ----------------------------------------
# Required for Dashboard access and saving multi-tenant architectures.
# Get free keys at: https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ----------------------------------------
# 2. Neo4j Graph Database
# ----------------------------------------
# Powers the Deterministic Graph Heuristics Intelligence engine.
# Use a local Neo4j Desktop instance or get a free AuraDB cloud instance: https://neo4j.com/cloud/platform/aura-graph-database/
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ----------------------------------------
# 3. Production Deployment Routing
# ----------------------------------------
# Set this ONLY if hosting the Next.js frontend on Vercel/Netlify.
# Point this to your Render/Railway FastAPI backend URL.
# (Leave completely blank/commented out for local localhost testing).
# BACKEND_URL=https://blackout-api.onrender.com
